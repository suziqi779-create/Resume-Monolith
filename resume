<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ziqi Su - Monolith Custom Resume</title>
    <style>
        :root {
            --bg-color: #0b130e; /* 五彩斑斓的黑：带有深绿底色的黑 */
            --text-main: #f4f7f5; /* 略带暖意、透气的白 */
            --text-muted: #8fa499; /* 灰绿，低调有质感 */
            --accent-green: #2e8b57; /* 凉爽初夏的深绿 */
            --laser-glow: rgba(46, 139, 87, 0.4);
            --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-sans);
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.7;
            padding: 40px 20px;
            overflow-x: hidden;
            position: relative;
        }

        /* 斑驳树影与清晨阳光的光影意境 */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.03) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(46, 139, 87, 0.05) 0%, transparent 50%);
            pointer-events: none;
            z-index: -1;
        }

        /* 连贯下滑的透气布局 */
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 60px 40px;
            background: rgba(11, 19, 14, 0.8);
            border-left: 1px solid rgba(46, 139, 87, 0.15); /* 模拟锋芒感的隐性切割线 */
            position: relative;
        }

        /* 核心符号：圆（永远保持求知欲的未知周长） */
        .circle-accent {
            position: absolute;
            top: 40px;
            right: 40px;
            width: 80px;
            height: 80px;
            border: 1px dashed rgba(46, 139, 87, 0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: var(--text-muted);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* 顶部信息 */
        header {
            margin-bottom: 80px;
        }

        .name-title {
            font-size: 2.5rem;
            font-weight: 300;
            letter-spacing: 4px;
            color: var(--text-main);
            margin-bottom: 15px;
            position: relative;
        }

        /* 激光切割的线性线索 */
        .name-title::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 60px;
            height: 1px;
            background: var(--accent-green);
            box-shadow: 0 0 8px var(--laser-glow);
        }

        .contact-info {
            font-size: 0.9rem;
            color: var(--text-muted);
            letter-spacing: 1px;
        }

        .contact-info span {
            margin-right: 20px;
        }

        /* 大面积留白的区块设计 */
        section {
            margin-bottom: 70px;
        }

        /* 带有锋芒感的无衬线标题 */
        h2 {
            font-size: 1.3rem;
            font-weight: 400;
            color: var(--accent-green);
            letter-spacing: 2px;
            margin-bottom: 30px;
            text-transform: uppercase;
            display: flex;
            align-items: center;
        }

        h2::before {
            content: '■';
            font-size: 8px;
            margin-right: 10px;
            color: var(--accent-green);
            opacity: 0.7;
        }

        .timeline-item {
            margin-bottom: 45px;
            position: relative;
        }

        .item-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 12px;
        }

        .item-title {
            font-size: 1.1rem;
            font-weight: 500;
            color: var(--text-main);
        }

        .item-meta {
            font-size: 0.9rem;
            color: var(--text-muted);
            text-align: right;
        }

        .sub-title {
            font-size: 0.95rem;
            color: var(--accent-green);
            margin-bottom: 10px;
            font-weight: 400;
        }

        /* 细腻平滑的列表描述 */
        ul {
            list-style: none;
        }

        li {
            font-size: 0.95rem;
            color: var(--text-main);
            margin-bottom: 8px;
            position: relative;
            padding-left: 15px;
        }

        li::before {
            content: '›';
            position: absolute;
            left: 0;
            color: var(--text-muted);
            font-weight: bold;
        }

        .highlight {
            color: #bbf2d6; /* 亮色，用于标明商业产出/数据结果 */
            font-weight: 500;
        }

        /* 契合Monolith话语体系的“算力、数据、算法”特殊容器 */
        .capability-block {
            background: rgba(46, 139, 87, 0.03);
            border: 1px solid rgba(46, 139, 87, 0.08);
            padding: 25px;
            margin-bottom: 35px;
            border-radius: 2px;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); /* 细腻平滑的微动效 */
        }

        .capability-block:hover {
            background: rgba(46, 139, 87, 0.05);
            border-color: rgba(46, 139, 87, 0.2);
            transform: translateX(3px);
        }

        .capability-tag {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #bbf2d6;
            margin-bottom: 15px;
            display: inline-block;
            border-bottom: 1px solid rgba(46, 139, 87, 0.3);
            padding-bottom: 2px;
        }

        /* 底部留白透气声明 */
        footer {
            margin-top: 100px;
            text-align: center;
            font-size: 0.8rem;
            color: var(--text-muted);
            letter-spacing: 2px;
            border-top: 1px solid rgba(46, 139, 87, 0.1);
            padding-top: 30px;
        }
    </style>
</head>
